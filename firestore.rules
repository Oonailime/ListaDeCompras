rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // Caminho de documentos de usuário é /users/{uid}
    // O documento contém {username, uid, email, ...}
    match /users/{uid} {
      allow create: if request.auth.uid == uid 
                       && request.resource.data.uid == request.auth.uid;
      allow read, update: if request.auth.uid == uid;
      allow delete: if false;  // nunca excluir via cliente
    }

    // Listas de compras - vinculadas ao username do usuário autenticado
    match /listas_de_compras/{listaId} {

  		allow create: if request.auth != null
    	&& request.resource.data.ownerUid == request.auth.uid;

  		allow read, update, delete: if request.auth != null
    	&& resource.data.ownerUid == request.auth.uid;
		}

    // Convites pendentes
    match /convites_pendentes/{inviteId} {

      allow create: if request.auth != null
        && request.resource.data.fromUsername ==
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.username;

      allow read: if request.auth != null
        && (
          resource.data.fromUsername ==
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.username
          ||
          resource.data.toUsername ==
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.username
        );

      allow update: if request.auth != null
        && resource.data.toUsername ==
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.username;

}

    // Produtos salvos
    match /produtos_salvar/{listaId} {

  		allow read, write: if request.auth != null
    	&& get(/databases/$(database)/documents/listas_de_compras/$(listaId)).data.ownerUid
       == request.auth.uid;

}

    // Nega tudo o mais
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
